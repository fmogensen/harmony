#!/usr/bin/env bash
# bin/harmony — single-entry CLI dispatcher for the harmony plugin.
#
# Usage:
#   harmony apply        [--quiet|--verbose] [--dry-run] [--no-wait]
#   harmony status
#   harmony verify
#   harmony diff
#   harmony init         [--force]
#   harmony promote      <plugin-id>     (TODO)
#   harmony demote       <plugin-id>     (TODO)
#   harmony promote-brew <formula>       (TODO)
#   harmony help
#   harmony version

set -o errexit
set -o nounset
set -o pipefail

# Resolve our own directory regardless of how we were invoked.
HARMONY_BIN_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
HARMONY_REPO_ROOT="$( cd "${HARMONY_BIN_DIR}/.." && pwd )"
HARMONY_LIB_DIR="${HARMONY_REPO_ROOT}/lib"

# shellcheck source=../lib/common.sh
source "${HARMONY_LIB_DIR}/common.sh"
# v2: git-sync + per-host overrides (both fail-open).
# shellcheck source=../lib/sync.sh
source "${HARMONY_LIB_DIR}/sync.sh"
# shellcheck source=../lib/overrides.sh
source "${HARMONY_LIB_DIR}/overrides.sh"

HARMONY_VERSION="0.1.0-dev"

# ---------- Argument parsing ----------
# Globals set from CLI flags. Domain libs read these.
HARMONY_DRY_RUN=0
HARMONY_NO_WAIT=0
# HARMONY_QUIET / HARMONY_VERBOSE are inherited from common.sh defaults.

parse_global_flags() {
    # Strip recognised global flags from the front of $@ and set globals.
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quiet)    HARMONY_QUIET=1;   shift ;;
            --verbose)  HARMONY_VERBOSE=1; shift ;;
            --dry-run)  HARMONY_DRY_RUN=1; shift ;;
            --no-wait)  HARMONY_NO_WAIT=1; shift ;;
            *) break ;;
        esac
    done
    HARMONY_REMAINING_ARGS=("$@")
    export HARMONY_QUIET HARMONY_VERBOSE HARMONY_DRY_RUN HARMONY_NO_WAIT
}

# ---------- Verb dispatch ----------

cmd_help() {
    cat <<'EOF'
harmony — declarative config for Claude Code.

Usage:
  harmony apply [--dry-run] [--quiet|--verbose] [--no-wait]
                          Reconcile your machine to the manifest.
  harmony status          Show what would change (read-only).
  harmony verify          Run all smoke-test assertions.
  harmony diff            Detailed JSON diff (manifest vs reality).
  harmony sync [--push]   Git-sync the config repo now (pull ff-only; push if
                          mode=pull-push, or --push to force the push once).
  harmony capture [--dry-run]
                          Add plugins/MCP servers installed on this machine but
                          missing from the manifest (the inverse of apply's
                          prune), then commit (and push if mode=pull-push).
  harmony init [--force]  Create your config directory from a starter template.
  harmony help            Show this message.
  harmony version         Print the harmony version.

Multi-Mac (v2): with a "sync" block in the manifest, apply does git pull
--ff-only on the config repo first (warns, never blocks, on divergence) and —
if mode=pull-push — pushes local commits after. A per-host
overrides/<hostname>.json is deep-merged over the base manifest.

Env vars:
  HARMONY_CONFIG_DIR     Path to your config repo (default: ~/code/harmony-config).
  HARMONY_VERBOSE        Set to 1 to enable debug logging.

See: https://github.com/fmogensen/harmony
EOF
}

cmd_version() {
    printf "harmony %s\n" "$HARMONY_VERSION"
}

cmd_apply() {
    # Also parse post-verb flags (--dry-run/--quiet/--verbose/--no-wait can
    # appear before OR after the verb).
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quiet)    HARMONY_QUIET=1;   shift ;;
            --verbose)  HARMONY_VERBOSE=1; shift ;;
            --dry-run)  HARMONY_DRY_RUN=1; shift ;;
            --no-wait)  HARMONY_NO_WAIT=1; shift ;;
            *)
                harmony_error "unknown flag for apply: $1"
                exit 1
                ;;
        esac
    done

    harmony_require_cmd jq "brew install jq"
    harmony_acquire_lock $([[ "$HARMONY_NO_WAIT" == "1" ]] && echo no-wait || echo wait)

    if ! harmony_config_exists; then
        harmony_warn "no manifest at $(harmony_manifest_path) — run 'harmony init' to create one"
        return 0
    fi

    local base_manifest
    base_manifest="$(harmony_manifest_path)"
    harmony_jq_validate "$base_manifest" "manifest"

    # v2: sync the config repo before reading it, so we apply the latest.
    # (Reads sync config from the on-disk manifest; pull is ff-only + warn.)
    harmony_sync_load "$base_manifest"
    if [[ "$HARMONY_DRY_RUN" == "1" ]]; then
        # status: report sync state instead of mutating anything.
        [[ "$HARMONY_SYNC_ENABLED" == "true" ]] && harmony_info "$(harmony_sync_report)"
    else
        harmony_sync_pull
    fi
    # Re-validate in case the pull updated the manifest.
    harmony_jq_validate "$base_manifest" "manifest"

    # v2: layer this host's overrides over the base → effective manifest.
    local manifest
    manifest="$(harmony_effective_manifest "$base_manifest")"
    harmony_on_exit 'harmony_overrides_cleanup'

    harmony_source_domains

    harmony_info "applying manifest: $manifest"
    [[ "$HARMONY_DRY_RUN" == "1" ]] && harmony_info "(dry-run — no changes will be made)"

    local domain plan_lines plan_count=0 change_count=0 error_count=0
    for domain in "${HARMONY_DOMAINS[@]}"; do
        # Skip domains whose library isn't loaded.
        if ! declare -F "harmony_domain_${domain}_plan" >/dev/null 2>&1; then
            harmony_debug "domain not implemented yet: $domain"
            continue
        fi

        harmony_debug "planning domain: $domain"
        plan_lines="$( "harmony_domain_${domain}_plan" "$manifest" || true )"

        if [[ -z "$plan_lines" ]]; then
            harmony_debug "domain $domain: in sync"
            continue
        fi

        # Count actions for the summary.
        local d_count
        d_count="$(printf "%s\n" "$plan_lines" | grep -cv '^noop' || true)"
        plan_count=$(( plan_count + d_count ))

        if [[ "$HARMONY_VERBOSE" == "1" ]] || [[ "$HARMONY_QUIET" != "1" && "$d_count" -gt 0 ]]; then
            printf "%s\n" "$plan_lines" | grep -v '^noop' | while IFS=$'\t' read -r action resource details; do
                harmony_info "[${domain}] ${action} ${resource}${details:+ — ${details}}"
            done
        fi

        if [[ "$HARMONY_DRY_RUN" != "1" ]]; then
            if "harmony_domain_${domain}_apply" "$manifest"; then
                change_count=$(( change_count + d_count ))
            else
                harmony_warn "domain $domain: apply failed (continuing)"
                error_count=$(( error_count + 1 ))
            fi
        fi
    done

    if [[ "$plan_count" -eq 0 ]]; then
        [[ "$HARMONY_QUIET" != "1" ]] && harmony_info "all in sync"
    else
        if [[ "$HARMONY_DRY_RUN" == "1" ]]; then
            harmony_info "would apply $plan_count change(s)"
        else
            harmony_info "applied $change_count change(s) (errors: $error_count)"
        fi
    fi

    # v2: push local config commits if sync mode is pull-push (opt-in, non-fatal).
    [[ "$HARMONY_DRY_RUN" == "1" ]] || harmony_sync_push
    return 0
}

cmd_status() {
    HARMONY_DRY_RUN=1
    HARMONY_QUIET=0
    cmd_apply
}

cmd_verify() {
    harmony_require_cmd jq "brew install jq"

    if ! harmony_config_exists; then
        harmony_error "no manifest at $(harmony_manifest_path)"
        return 1
    fi

    local manifest
    manifest="$(harmony_manifest_path)"
    harmony_jq_validate "$manifest" "manifest"

    harmony_source_domains

    local domain ok=0 fail=0
    for domain in "${HARMONY_DOMAINS[@]}"; do
        if ! declare -F "harmony_domain_${domain}_verify" >/dev/null 2>&1; then
            continue
        fi
        if "harmony_domain_${domain}_verify" "$manifest"; then
            printf "PASS  %-12s in sync\n" "$domain"
            ok=$(( ok + 1 ))
        else
            printf "FAIL  %-12s drift detected (run 'harmony status' for details)\n" "$domain"
            fail=$(( fail + 1 ))
        fi
    done

    # v2.1: report git-sync health as its own row (only when sync is enabled).
    harmony_sync_load "$manifest"
    if [[ "$HARMONY_SYNC_ENABLED" == "true" ]]; then
        local sync_msg
        if sync_msg="$(harmony_sync_report)"; then
            printf "PASS  %-12s %s\n" "sync" "${sync_msg#sync: }"
            ok=$(( ok + 1 ))
        else
            printf "WARN  %-12s %s\n" "sync" "${sync_msg#sync: }"
            # sync attention is a WARN, not a hard FAIL — it never blocks.
        fi
    fi

    printf "\n%d passed, %d failed\n" "$ok" "$fail"
    [[ "$fail" -eq 0 ]]
}

cmd_diff() {
    # Detailed diff: just status, but verbose.
    HARMONY_VERBOSE=1
    cmd_status
}

cmd_sync() {
    # On-demand git-sync of the config repo, independent of apply.
    #   harmony sync         pull (and push if mode=pull-push)
    #   harmony sync --push  force the push leg too (one-off, regardless of mode)
    local force_push=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --push) force_push=1; shift ;;
            *) harmony_error "unknown flag for sync: $1"; exit 1 ;;
        esac
    done

    harmony_require_cmd jq "brew install jq"
    if ! harmony_config_exists; then
        harmony_die "no manifest at $(harmony_manifest_path)"
    fi
    local manifest
    manifest="$(harmony_manifest_path)"
    harmony_sync_load "$manifest"

    if [[ "$HARMONY_SYNC_ENABLED" != "true" ]]; then
        harmony_warn "sync is disabled in the manifest (set .sync.enabled = true to enable)"
        return 0
    fi

    harmony_sync_pull
    if [[ "$force_push" == "1" ]]; then
        HARMONY_SYNC_MODE="pull-push"
    fi
    harmony_sync_push
    return 0
}

cmd_capture() {
    # Reverse reconcile: add config installed on THIS machine but missing from
    # the manifest (the inverse of apply's prune). v1 scope: plugins + MCP
    # servers — the things you install in a session that would otherwise be
    # pruned next start or never sync to other Macs.
    #
    #   harmony capture            write manifest, commit, push if mode=pull-push
    #   harmony capture --dry-run  print what would be added; write nothing
    local dry=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry=1; shift ;;
            *) harmony_error "unknown flag for capture: $1"; exit 1 ;;
        esac
    done

    harmony_require_cmd jq "brew install jq"
    if ! harmony_config_exists; then
        harmony_die "no manifest at $(harmony_manifest_path)"
    fi
    local manifest
    manifest="$(harmony_manifest_path)"
    harmony_jq_validate "$manifest" "manifest"
    harmony_source_domains

    # --- Gather capturable items from the domains ---
    local plugin_ids mcp_lines
    plugin_ids="$(harmony_domain_plugins_capture "$manifest" 2>/dev/null || true)"

    local mcp_capturable="" mcp_skipped=""
    if declare -F harmony_domain_mcp_capture >/dev/null 2>&1; then
        local _line
        while IFS= read -r _line; do
            [[ -z "$_line" ]] && continue
            if [[ "$_line" == SKIP$'\t'* ]]; then
                mcp_skipped+="${_line#SKIP$'\t'}"$'\n'
            else
                mcp_capturable+="$_line"$'\n'
            fi
        done < <(harmony_domain_mcp_capture "$manifest" 2>/dev/null || true)
    fi

    # Nothing to do?
    local p_count m_count
    p_count="$(printf "%s" "$plugin_ids" | grep -c . || true)"
    m_count="$(printf "%s" "$mcp_capturable" | grep -c . || true)"
    if [[ "$p_count" -eq 0 && "$m_count" -eq 0 ]]; then
        harmony_info "nothing to capture — manifest already matches installed plugins/MCP servers"
        [[ -n "$mcp_skipped" ]] && printf "%s" "$mcp_skipped" | while IFS=$'\t' read -r k reason; do
            harmony_warn "mcp.${k} not captured: ${reason}"
        done
        return 0
    fi

    # --- Report ---
    local id
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        harmony_info "[capture] plugin ${id} → manifest.plugins[]"
    done <<< "$plugin_ids"
    printf "%s" "$mcp_capturable" | while IFS=$'\t' read -r k _cfg; do
        [[ -z "$k" ]] && continue
        harmony_info "[capture] mcp ${k} → manifest.mcpServers.servers"
    done
    [[ -n "$mcp_skipped" ]] && printf "%s" "$mcp_skipped" | while IFS=$'\t' read -r k reason; do
        harmony_warn "[capture] mcp ${k} SKIPPED: ${reason}"
    done

    if [[ "$dry" == "1" ]]; then
        harmony_info "(dry-run — manifest not modified)"
        return 0
    fi

    # --- Write the manifest (atomic, backed up) ---
    local updated
    updated="$(cat "$manifest")"

    # Plugins: append { id, enabled:true } for each, deduped.
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        updated="$(printf "%s" "$updated" | jq --arg i "$id" '
            .plugins = (.plugins // [])
            | if any(.plugins[]; .id == $i) then .
              else .plugins += [ { "id": $i, "enabled": true } ] end')"
    done <<< "$plugin_ids"

    # MCP servers: set servers[key] = captured config. Use process substitution
    # (not a pipe) so the loop runs in THIS shell and can mutate $updated.
    local k cfg
    while IFS=$'\t' read -r k cfg; do
        [[ -z "$k" ]] && continue
        updated="$(printf "%s" "$updated" | jq --arg k "$k" --argjson c "$cfg" '
            .mcpServers = (.mcpServers // {})
            | .mcpServers.servers = (.mcpServers.servers // {})
            | .mcpServers.servers[$k] = $c')"
    done < <(printf "%s" "$mcp_capturable")

    printf "%s" "$updated" | harmony_jq_write_atomic "$manifest"
    harmony_info "captured $((p_count + m_count)) item(s) into $manifest"

    # --- Commit + push (reuse sync machinery for the push leg) ---
    if harmony_have_cmd git && git -C "$HARMONY_CONFIG_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        local summary
        summary="$(printf "%s" "$plugin_ids" | tr '\n' ' ')"
        git -C "$HARMONY_CONFIG_DIR" add -A 2>/dev/null || true
        if git -C "$HARMONY_CONFIG_DIR" commit -q -m "harmony capture: ${summary}${mcp_capturable:+mcp servers}" 2>/dev/null; then
            harmony_info "committed capture to $HARMONY_CONFIG_DIR"
            harmony_sync_load "$manifest"
            harmony_sync_push
        else
            harmony_warn "nothing committed (no git changes?)"
        fi
    else
        harmony_warn "$HARMONY_CONFIG_DIR is not a git repo — manifest written but not committed"
    fi
    return 0
}

cmd_init() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force=1; shift ;;
            *) shift ;;
        esac
    done

    if [[ -d "$HARMONY_CONFIG_DIR" && "$force" != "1" ]]; then
        harmony_die "$HARMONY_CONFIG_DIR already exists (pass --force to overwrite)"
    fi

    local example="${HARMONY_REPO_ROOT}/examples/single-mac.json"
    if [[ ! -f "$example" ]]; then
        harmony_die "starter example not found at $example"
    fi

    mkdir -p "$HARMONY_CONFIG_DIR"/{content/{skills,agents,commands},settings,hooks,helpers,launchd}
    cp "$example" "$(harmony_manifest_path)"

    # Symlink ~/.local/bin/harmony so the CLI is on PATH.
    mkdir -p "${HOME}/.local/bin"
    if [[ ! -L "${HOME}/.local/bin/harmony" ]]; then
        ln -sf "${HARMONY_REPO_ROOT}/bin/harmony" "${HOME}/.local/bin/harmony"
        harmony_info "symlinked ${HOME}/.local/bin/harmony -> ${HARMONY_REPO_ROOT}/bin/harmony"
        if ! printf "%s" "$PATH" | tr ':' '\n' | grep -qx "${HOME}/.local/bin"; then
            harmony_warn "${HOME}/.local/bin is not on \$PATH — add it to your shell profile to use 'harmony' from any terminal"
        fi
    fi

    harmony_info "created $HARMONY_CONFIG_DIR from $example"
    harmony_info "edit $(harmony_manifest_path), then run 'harmony apply'"
}

# ---------- Main ----------

parse_global_flags "$@"
set -- "${HARMONY_REMAINING_ARGS[@]:-}"

if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

verb="$1"; shift
case "$verb" in
    apply)         cmd_apply "$@" ;;
    status)        cmd_status "$@" ;;
    verify)        cmd_verify "$@" ;;
    diff)          cmd_diff "$@" ;;
    sync)          cmd_sync "$@" ;;
    capture)       cmd_capture "$@" ;;
    init)          cmd_init "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) cmd_version ;;
    promote|demote|promote-brew)
        harmony_die "verb '$verb' not yet implemented (planned for v1)"
        ;;
    *)
        harmony_error "unknown verb: $verb"
        cmd_help
        exit 1
        ;;
esac
